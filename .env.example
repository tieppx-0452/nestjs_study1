PORT=3000

# Supabase Postgres connection (Project Settings > Database > Connection string)
# Dùng Connection Pooling (port 6543) cho serverless, hoặc direct connection (port 5432)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# JWT auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d
